'use client';

import React, { createContext, useContext, useState, useEffect } from 'react';
import profileData from '../../data/profile.json';

interface ToolMetric {
  name: string;
  level: number;
}

interface CompetencyMetric {
  name: string;
  level: number;
}

interface FAQItem {
  question: string;
  answer: string;
}

interface PortfolioContextProps {
  profile: {
    name: string;
    roles: string[];
    email: string;
    avatarUrl: string;
    bio: string;
  };
  metrics: {
    tools: ToolMetric[];
    competencies: CompetencyMetric[];
  };
  faqs: FAQItem[];
  activeProjectSlug: string | null;
  setActiveProjectSlug: (slug: string | null) => void;
}

const PortfolioContext = createContext<PortfolioContextProps | undefined>(undefined);

export const PortfolioProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const [activeProjectSlug, setActiveProjectSlug] = useState<string | null>(null);

  return (
    <PortfolioContext.Provider value= {{ ...profileData, activeProjectSlug, setActiveProjectSlug }
}>
  { children }
  </PortfolioContext.Provider>
  );
};

export const usePortfolio = () => {
  const context = useContext(PortfolioContext);
  if (!context) {
    throw new Error('usePortfolio must be used within a PortfolioProvider');
  }
  return context;
};